---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import LegalSection from '../components/LegalSection.astro';
import LegalBullet from '../components/LegalBullet.astro';
import { site } from '../content/site';
---

<BaseLayout
  title={`이용약관 | ${site.serviceName}`}
  description={`${site.serviceName} 이용약관. 운영: ${site.companyName}.`}
  path="/terms"
>
  <header class="border-b border-[var(--color-rule)]">
    <div class="mx-auto max-w-3xl px-5 py-4">
      <SiteHeader size="sm" />
    </div>
  </header>

  <main class="mx-auto max-w-3xl flex-1 px-5 py-10">
    <h1 class="text-3xl font-bold tracking-tight text-[var(--color-ink)]">이용약관</h1>
    <p class="mt-2 text-sm font-medium text-[var(--color-muted)]">시행일 {site.termsEffectiveDate}</p>

    <div class="mt-8">
      <LegalSection title="제1조 (목적)">
        <p>
          본 약관은 {site.serviceName}(이하 &ldquo;서비스&rdquo;)이 제공하는 출장 청소업체 예약 관리
          모바일 애플리케이션 및 부속 기능의 이용 조건과 절차, 회원과 서비스 운영자({site.companyName})의
          권리·의무 및 책임 사항을 규정하는 것을 목적으로 합니다.
        </p>
      </LegalSection>

      <LegalSection title="제2조 (정의)">
        <LegalBullet>&ldquo;회원&rdquo;이란 본 약관에 동의하고 서비스에 가입하여 사업자 또는 그 직원으로 서비스를 이용하는 자를 말합니다.</LegalBullet>
        <LegalBullet>&ldquo;사업장&rdquo;이란 회원이 등록한 청소업체 단위를 의미하며, 다수의 직원 계정이 하나의 사업장에 속할 수 있습니다.</LegalBullet>
        <LegalBullet>&ldquo;콘텐츠&rdquo;란 회원이 서비스에 입력·업로드한 예약, 고객, 매출, 이미지 등의 모든 데이터를 의미합니다.</LegalBullet>
      </LegalSection>

      <LegalSection title="제3조 (약관의 효력 및 변경)">
        <p>
          본 약관은 회원이 가입 시 동의함으로써 효력이 발생합니다. 운영자는 관련 법령을
          위반하지 않는 범위에서 약관을 개정할 수 있으며, 중대한 변경이 있을 경우 시행일
          최소 7일 전에 앱 내 공지 또는 이메일로 안내합니다.
        </p>
      </LegalSection>

      <LegalSection title="제4조 (회원 가입 및 계정)">
        <LegalBullet>가입은 이메일·비밀번호 인증만으로 이루어지며, 실명 또는 사업장명을 기재해야 합니다.</LegalBullet>
        <LegalBullet>회원은 계정 정보의 기밀 유지에 책임을 지며, 제3자와 공유할 수 없습니다.</LegalBullet>
        <LegalBullet>타인의 정보를 도용하거나 허위 정보를 기재한 가입은 사전 통지 없이 해지될 수 있습니다.</LegalBullet>
      </LegalSection>

      <LegalSection title="제5조 (서비스 제공)">
        <p>
          서비스는 예약 일정 관리, 고객 관리, 매출·인센티브 집계, 직원 협업 기능을
          제공합니다. 카카오 알림톡 등 외부 연동 기능은 별도의 고지와 함께 단계적으로
          활성화될 수 있습니다.
        </p>
      </LegalSection>

      <LegalSection title="제6조 (요금 정책)">
        <p>
          회원 추가 시 추가 과금은 발생하지 않습니다. 유료 기능이 도입될 경우 사전에
          명확히 고지하며, 회원 동의 없이 결제가 일어나지 않습니다.
        </p>
      </LegalSection>

      <LegalSection title="제7조 (데이터 오너십과 내보내기)">
        <p>
          회원이 입력한 콘텐츠의 소유권은 전적으로 회원 및 사업장에 귀속됩니다.
          회원은 언제든지 앱 내 기능을 통해 고객·예약·매출 데이터를 CSV로 내보낼 수
          있으며, 서비스 해지 이후에도 합리적 기간 내에 내보내기가 지원됩니다.
        </p>
      </LegalSection>

      <LegalSection title="제8조 (회원의 의무)">
        <LegalBullet>관련 법령, 본 약관, 서비스 운영 정책을 준수해야 합니다.</LegalBullet>
        <LegalBullet>타인의 권리나 명예를 침해하는 콘텐츠를 등록해서는 안 됩니다.</LegalBullet>
        <LegalBullet>서비스의 정상적 운영을 방해하는 행위(부정 접근, 과도한 자동화 등)를 해서는 안 됩니다.</LegalBullet>
      </LegalSection>

      <LegalSection title="제9조 (서비스의 중단)">
        <p>
          운영자는 시스템 점검, 장애, 천재지변 등 불가항력적 사유로 서비스 제공을 일시
          중단할 수 있으며, 가능한 범위에서 사전 또는 사후에 공지합니다.
        </p>
      </LegalSection>

      <LegalSection title="제10조 (책임의 제한)">
        <p>
          운영자는 무상으로 제공되는 기능에 관하여 관련 법령이 허용하는 최대 한도 내에서
          책임을 부담합니다. 회원의 귀책사유로 인한 데이터 손실, 제3자 서비스(카카오,
          Supabase 등) 장애에 따른 손해에 대해서는 면책됩니다.
        </p>
      </LegalSection>

      <LegalSection title="제11조 (계약 해지)">
        <p>
          회원은 언제든지 앱 내 기능 또는 운영자에게 서면으로 해지 의사를 표시하여 탈퇴할
          수 있으며, 탈퇴 즉시 개인식별정보는 관련 법령이 정한 범위를 제외하고 파기됩니다.
        </p>
      </LegalSection>

      <LegalSection title="제12조 (분쟁 해결)">
        <p>
          본 약관에 관한 분쟁은 대한민국 법을 준거법으로 하며, 운영자의 주소지를 관할하는
          법원을 제1심 전속 관할 법원으로 합니다.
        </p>
      </LegalSection>
    </div>

    <p class="mt-8 border-t border-[var(--color-rule)] pt-6 text-sm text-[var(--color-muted)]">
      문의: <a href={`mailto:${site.email}`}>{site.email}</a>
    </p>
  </main>
</BaseLayout>
