---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import LegalSection from '../components/LegalSection.astro';
import LegalBullet from '../components/LegalBullet.astro';
import { site } from '../content/site';
---

<BaseLayout
  title={`개인정보처리방침 | ${site.serviceName}`}
  description={`${site.serviceName} 개인정보처리방침. 운영: ${site.companyName}.`}
  path="/privacy"
>
  <header class="border-b border-[var(--color-rule)]">
    <div class="mx-auto max-w-3xl px-5 py-4">
      <SiteHeader size="sm" />
    </div>
  </header>

  <main class="mx-auto max-w-3xl flex-1 px-5 py-10">
    <h1 class="text-3xl font-bold tracking-tight text-[var(--color-ink)]">개인정보처리방침</h1>
    <p class="mt-2 text-sm font-medium text-[var(--color-muted)]">시행일 {site.privacyEffectiveDate}</p>

    <p class="mt-6 text-[15px] leading-relaxed text-[var(--color-ink-2)]">
      {site.serviceName}은 「개인정보 보호법」에 따라 이용자의 개인정보를 보호하고 개인정보와
      관련한 문의를 신속하게 처리하기 위해 본 방침을 수립합니다. 본 서비스는 {site.companyName}(대표 {site.representative})이 운영합니다.
    </p>

    <div class="mt-8">
      <LegalSection title="1. 처리하는 개인정보">
        <LegalBullet>계정 정보: 이메일 주소, 비밀번호 해시값, 이름, 휴대폰 번호</LegalBullet>
        <LegalBullet>사업장 정보: 사업장명, 대표 연락처, 사업자번호, 계좌 정보, 주소</LegalBullet>
        <LegalBullet>고객·예약 정보: 고객 이름, 연락처, 주소, 예약 일정, 작업 메모, 작업 사진</LegalBullet>
        <LegalBullet>매출·직원 정보: 매출 금액, 결제수단 텍스트, 직원 이름, 연락처, 이메일, 역할, 인센티브율</LegalBullet>
        <LegalBullet>운영 정보: 앱 버전, 기기 모델, OS 버전, IP 주소, 접속 일시, 오류 로그, 푸시 알림 토큰</LegalBullet>
      </LegalSection>

      <LegalSection title="2. 처리 목적">
        <LegalBullet>회원 식별, 로그인, 계정 관리, 고객 지원</LegalBullet>
        <LegalBullet>예약·고객·매출·인센티브·직원 관리 기능 제공</LegalBullet>
        <LegalBullet>예약 리마인드 등 사용자가 허용한 알림 발송</LegalBullet>
        <LegalBullet>오류 진단, 보안 로그 확인, 장애 대응</LegalBullet>
        <LegalBullet>제품 이용 분석 및 서비스 개선 (광고·마케팅 목적 아님)</LegalBullet>
      </LegalSection>

      <LegalSection title="3. 보유 및 이용 기간">
        <LegalBullet>회원·사업장·고객·예약·매출·직원 정보: 회원 탈퇴 또는 계정 삭제 요청 시까지</LegalBullet>
        <LegalBullet>이용자가 삭제한 서비스 데이터: 최대 90일간 복구 가능 상태로 보관 후 영구 파기</LegalBullet>
        <LegalBullet>오류·충돌 로그: 수집일로부터 최대 90일</LegalBullet>
        <LegalBullet>법령상 보관 의무가 있는 정보: 해당 법령에서 정한 기간</LegalBullet>
      </LegalSection>

      <LegalSection title="4. 선택 권한">
        <LegalBullet>사진 및 미디어: 작업 사진을 사진 라이브러리에서 불러오기</LegalBullet>
        <LegalBullet>연락처: 신규 고객 추가 시 사용자가 선택한 연락처의 이름·전화번호 불러오기</LegalBullet>
        <LegalBullet>알림: 예약 리마인드 등 앱 알림 발송</LegalBullet>
        <p class="mt-2 text-[15px] leading-relaxed text-[var(--color-ink-2)]">
          선택 권한을 허용하지 않아도 해당 기능을 제외한 서비스 이용은 가능합니다.
        </p>
      </LegalSection>

      <LegalSection title="5. 제3자 제공">
        <p>
          서비스는 이용자의 개인정보를 광고·마케팅 목적으로 판매하거나 임대하지 않습니다.
          이용자의 사전 동의가 있거나 법령에 특별한 규정이 있는 경우를 제외하고
          개인정보를 제3자에게 제공하지 않습니다.
        </p>
      </LegalSection>

      <LegalSection title="6. 처리 위탁 및 국외 이전">
        <LegalBullet>Supabase Inc. — 인증, 데이터베이스, 파일 저장소, 실시간 데이터 처리</LegalBullet>
        <LegalBullet>Functional Software, Inc. (Sentry) — 앱 오류·충돌 로그 수집 및 분석</LegalBullet>
        <LegalBullet>PostHog, Inc. — 제품 이용 분석, 화면 이동 이벤트 수집 (광고 추적 아님)</LegalBullet>
        <LegalBullet>Expo, Inc. — 앱 빌드, 업데이트, 푸시 알림 토큰 처리</LegalBullet>
        <p class="mt-2">
          위 수탁자는 미국에서 개인정보를 처리할 수 있으며, 전송은 HTTPS/TLS 등
          암호화된 통신으로 이루어집니다.
        </p>
      </LegalSection>

      <LegalSection title="7. 안전성 확보 조치">
        <LegalBullet>비밀번호 단방향 해시 저장</LegalBullet>
        <LegalBullet>전송 구간 HTTPS/TLS 암호화</LegalBullet>
        <LegalBullet>데이터베이스 접근 권한 분리 및 최소 권한 적용</LegalBullet>
        <LegalBullet>사업장 단위 데이터 접근 제어</LegalBullet>
        <LegalBullet>오류 로그 내 민감정보 수집 최소화</LegalBullet>
      </LegalSection>

      <LegalSection title="8. 회원의 권리">
        <p>
          이용자는 언제든지 서비스 내 제공 기능 또는 이메일 문의를 통해 다음을 요청할 수
          있습니다.
        </p>
        <LegalBullet>개인정보 열람 및 정정</LegalBullet>
        <LegalBullet>삭제, 처리정지, 동의 철회</LegalBullet>
        <LegalBullet>계정 삭제 요청</LegalBullet>
        <p class="mt-2">
          계정 및 관련 데이터 삭제 요청 방법은 <a href="/delete-account">계정 삭제 요청 안내</a>에서 확인할 수 있습니다.
        </p>
      </LegalSection>

      <LegalSection title="9. 쿠키 및 추적 기술">
        <p>
          서비스는 모바일 앱으로서 웹 브라우저 쿠키를 사용하지 않습니다. 광고 목적의
          추적 도구나 광고 식별자(ADID/IDFA)를 사용하지 않습니다.
        </p>
      </LegalSection>

      <LegalSection title="10. 개인정보 보호책임자">
        <LegalBullet>책임자: {site.privacyOfficer}</LegalBullet>
        <LegalBullet>이메일: {site.email}</LegalBullet>
        <LegalBullet>연락처: {site.phone}</LegalBullet>
        <p class="mt-2">
          이용자는 서비스 이용 중 발생한 모든 개인정보 관련 문의, 불만 처리, 피해 구제를
          위 연락처로 요청할 수 있습니다.
        </p>
      </LegalSection>

      <LegalSection title="11. 방침의 변경">
        <p>
          본 방침이 변경되는 경우 변경 내용과 시행일을 서비스 내 공지 또는
          개인정보처리방침 게시 페이지를 통해 안내합니다.
        </p>
      </LegalSection>
    </div>

    <p class="mt-8 border-t border-[var(--color-rule)] pt-6 text-sm text-[var(--color-muted)]">
      문의: <a href={`mailto:${site.email}`}>{site.email}</a>
    </p>
  </main>
</BaseLayout>
