---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import LegalSection from '../components/LegalSection.astro';
import LegalBullet from '../components/LegalBullet.astro';
import { site } from '../content/site';
---

<BaseLayout
  title={`계정 및 데이터 삭제 요청 | ${site.serviceName}`}
  description={`${site.serviceName} 계정 및 데이터 삭제 요청 안내. 운영: ${site.companyName}.`}
  path="/delete-account"
>
  <header class="border-b border-[var(--color-rule)]">
    <div class="mx-auto max-w-3xl px-5 py-4">
      <SiteHeader size="sm" />
    </div>
  </header>

  <main class="mx-auto max-w-3xl flex-1 px-5 py-10">
    <h1 class="text-3xl font-bold tracking-tight text-[var(--color-ink)]">계정 및 데이터 삭제 요청</h1>
    <p class="mt-2 text-sm font-medium text-[var(--color-muted)]">
      {site.serviceName} · 운영자 {site.companyName}
    </p>

    <p class="mt-6 text-[15px] leading-relaxed text-[var(--color-ink-2)]">
      {site.serviceName} 이용자는 언제든지 계정과 관련 데이터 삭제를 요청할 수 있습니다.
      요청은 아래 이메일로 접수하며, 본인 확인 후 처리합니다.
    </p>

    <div class="mt-8">
      <LegalSection title="1. 앱 및 개발자 정보">
        <LegalBullet>앱 이름: {site.serviceName}</LegalBullet>
        <LegalBullet>개발자/운영자: {site.companyName} (대표 {site.representative})</LegalBullet>
        <LegalBullet>문의 이메일: {site.email}</LegalBullet>
      </LegalSection>

      <LegalSection title="2. 계정 삭제 요청 방법">
        <p>
          아래 이메일 주소로 계정 삭제 요청을 보내 주세요.
        </p>
        <p class="mt-3 rounded-2xl border border-[var(--color-rule)] bg-[var(--color-paper)] p-4 font-semibold text-[var(--color-ink)]">
          <a href={`mailto:${site.email}?subject=${encodeURIComponent(`${site.serviceName} 계정 삭제 요청`)}`}>
            {site.email}
          </a>
        </p>
        <LegalBullet>이메일 제목: {site.serviceName} 계정 삭제 요청</LegalBullet>
        <LegalBullet>이메일 본문: 가입 이메일 주소, 사업장명, 삭제 요청 범위를 작성해 주세요.</LegalBullet>
        <LegalBullet>보안을 위해 요청 계정의 소유자 확인이 필요할 수 있습니다.</LegalBullet>
      </LegalSection>

      <LegalSection title="3. 삭제되는 데이터 종류">
        <LegalBullet>계정 정보: 이메일 주소, 이름, 휴대폰 번호 등 회원 정보</LegalBullet>
        <LegalBullet>사업장 정보: 사업장명, 대표 연락처, 주소, 설정 정보</LegalBullet>
        <LegalBullet>업무 데이터: 고객, 예약, 직원, 매출, 작업 메모, 첨부 사진 등 서비스 이용 중 입력한 데이터</LegalBullet>
        <LegalBullet>운영 데이터: 푸시 알림 토큰, 제품 분석 식별자 등 계정과 연결된 운영 정보</LegalBullet>
      </LegalSection>

      <LegalSection title="4. 보관되는 데이터 종류 및 보관 기간">
        <LegalBullet>법령상 보관 의무가 있는 정보: 해당 법령에서 정한 기간 동안 보관될 수 있습니다.</LegalBullet>
        <LegalBullet>백업 데이터: 삭제 요청 처리 전 백업에 포함된 데이터는 최대 90일간 복구 가능 상태로 남을 수 있으며, 이후 영구 삭제됩니다.</LegalBullet>
        <LegalBullet>오류·충돌 로그 등 보안 및 장애 대응용 기록: 수집일로부터 최대 90일간 보관될 수 있습니다.</LegalBullet>
        <LegalBullet>부정 이용 방지, 분쟁 대응, 법적 의무 이행에 필요한 최소 정보: 목적 달성 시까지 제한적으로 보관될 수 있습니다.</LegalBullet>
      </LegalSection>

      <LegalSection title="5. 계정 삭제 없이 일부 데이터 삭제를 요청하는 방법">
        <p>
          계정을 삭제하지 않고 고객, 예약, 매출, 직원 등 일부 데이터의 삭제나 정정을 요청할 수도 있습니다.
          앱 내 제공 기능으로 직접 수정·삭제하거나, 위 이메일로 요청해 주세요.
        </p>
      </LegalSection>

      <LegalSection title="6. 처리 안내">
        <LegalBullet>요청 접수 후 본인 확인과 처리 범위 확인을 진행합니다.</LegalBullet>
        <LegalBullet>삭제가 완료되면 회신 이메일로 처리 결과를 안내합니다.</LegalBullet>
        <LegalBullet>계정 삭제 후에는 기존 계정, 사업장, 예약, 고객, 매출 데이터에 접근할 수 없습니다.</LegalBullet>
      </LegalSection>
    </div>
  </main>
</BaseLayout>
