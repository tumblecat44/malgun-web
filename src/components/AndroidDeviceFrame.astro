---
interface Props {
  src: string;
  alt: string;
  class?: string;
}

const { src, alt, class: className } = Astro.props;
---

<div
  class:list={['hero-device mx-auto w-[200px] sm:w-[220px] md:w-[240px]', className]}
>
  <!-- ponytail: double-bezel shell, fixed max width ~240px -->
  <div
    class="rounded-[1.75rem] bg-[#e8eaed] p-1.5 ring-1 ring-[rgba(8,8,8,0.06)] shadow-[0_20px_50px_rgba(8,8,8,0.12),0_4px_12px_rgba(8,8,8,0.06)] transition-transform duration-700 ease-[cubic-bezier(0.32,0.72,0,1)] hover:-translate-y-1"
  >
    <div
      class="overflow-hidden rounded-[1.35rem] bg-[#1a1a1a] shadow-[inset_0_1px_0_rgba(255,255,255,0.12)]"
    >
      <div class="flex items-center justify-between bg-[#1a1a1a] px-3 pb-1 pt-2">
        <span class="text-[9px] font-medium tabular-nums text-white/70">9:41</span>
        <div class="h-2 w-2 rounded-full bg-[#2a2a2a] ring-1 ring-white/10" aria-hidden="true"></div>
        <div class="flex gap-0.5" aria-hidden="true">
          <span class="h-2 w-2 rounded-sm bg-white/50"></span>
          <span class="h-2 w-3 rounded-sm bg-white/50"></span>
        </div>
      </div>
      <div class="relative aspect-[9/19.5] overflow-hidden bg-white">
        <img
          src={src}
          alt={alt}
          width={390}
          height={844}
          class="absolute inset-0 h-full w-full object-cover object-top"
          loading="eager"
          decoding="async"
        />
      </div>
      <div class="flex justify-center bg-[#1a1a1a] py-1.5" aria-hidden="true">
        <span class="h-1 w-16 rounded-full bg-white/25"></span>
      </div>
    </div>
  </div>
</div>

<style>
  @media (prefers-reduced-motion: no-preference) {
    .hero-device {
      animation: hero-device-in 900ms cubic-bezier(0.32, 0.72, 0, 1) both;
    }
  }

  @keyframes hero-device-in {
    from {
      opacity: 0;
      transform: translateY(1.25rem);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-device {
      animation: none;
    }
  }
</style>
