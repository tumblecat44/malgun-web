---
import { site } from '../content/site';
---

<footer class="border-t border-[var(--color-rule)] bg-[var(--color-bg-soft)]">
  <div class="mx-auto max-w-5xl px-5 py-10">
    <div class="mb-8 grid gap-6 sm:grid-cols-2">
      <div>
        <p class="mb-2 text-sm font-bold text-[var(--color-ink)]">사업자 정보</p>
        <dl class="space-y-1 text-sm text-[var(--color-ink-2)]">
          <div class="flex gap-2">
            <dt class="shrink-0 font-medium text-[var(--color-muted)]">상호</dt>
            <dd>{site.companyName}</dd>
          </div>
          <div class="flex gap-2">
            <dt class="shrink-0 font-medium text-[var(--color-muted)]">대표</dt>
            <dd>{site.representative}</dd>
          </div>
          <div class="flex gap-2">
            <dt class="shrink-0 font-medium text-[var(--color-muted)]">사업자등록번호</dt>
            <dd>{site.businessNumber}</dd>
          </div>
          <div class="flex gap-2">
            <dt class="shrink-0 font-medium text-[var(--color-muted)]">주소</dt>
            <dd>{site.address}</dd>
          </div>
          <div class="flex gap-2">
            <dt class="shrink-0 font-medium text-[var(--color-muted)]">연락처</dt>
            <dd>
              <a href={`tel:${site.phone.replace(/-/g, '')}`}>{site.phone}</a>
            </dd>
          </div>
          <div class="flex gap-2">
            <dt class="shrink-0 font-medium text-[var(--color-muted)]">이메일</dt>
            <dd>
              <a href={`mailto:${site.email}`}>{site.email}</a>
            </dd>
          </div>
        </dl>
      </div>
      <div>
        <p class="mb-2 text-sm font-bold text-[var(--color-ink)]">서비스</p>
        <p class="mb-4 text-sm leading-relaxed text-[var(--color-ink-2)]">
          {site.relationLine}
        </p>
        <nav class="flex flex-wrap gap-x-4 gap-y-2 text-sm font-medium">
          <a href="/terms">이용약관</a>
          <a href="/privacy">개인정보처리방침</a>
          <a href="/#features">기능 소개</a>
          <a href="/#contact">문의</a>
        </nav>
      </div>
    </div>
    <p class="text-xs text-[var(--color-muted)]">
      © {new Date().getFullYear()} {site.companyName}. {site.serviceName} 공식 홈페이지.
    </p>
  </div>
</footer>
